{
  "name": "cosmic-neighborhood-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "audit:cloudflare": "tsx scripts/audit-cloudflare-limits.ts",
    "build": "npm run build --workspaces",
    "cloudflare:configure": "tsx scripts/configure-cloudflare.ts",
    "data:generate": "npm --workspace packages/data run generate",
    "data:publish": "npm --workspace packages/data run publish",
    "deploy": "npm run deploy:api && npm run deploy:web",
    "deploy:api": "npm --workspace apps/api run deploy",
    "deploy:web": "npm --workspace apps/web run deploy",
    "dev": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "smoke:live": "tsx scripts/live-smoke.ts",
    "test": "vitest run",
    "typecheck": "npm run typecheck:scripts && npm run typecheck --workspaces",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.7",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.23.0"
  }
}
